# Copy this file to .env.local and fill in your Supabase project values.
# (.env.local is gitignored — never commit real keys.)
#
# Find these in the Supabase dashboard: Project Settings → API.
# The anon key is safe to ship in a frontend; Row-Level Security is what
# actually protects the data (see supabase/schema.sql).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
